{
  "version": 2,
  "public": true,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/auth/register", "destination": "/api/usuarios?route=register" },
    { "source": "/auth/login", "destination": "/api/usuarios?route=login" },
    { "source": "/auth/me", "destination": "/api/usuarios?route=me" },
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ]
}
